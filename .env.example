# LeetCoach configuration. Copy to ".env" and edit, or set these in your shell.
# All five are optional; the defaults shown work on a machine where the
# `claude` CLI is on PATH and you want the strongest model.

# Claude model id passed to `claude --model`. Use a full id (claude-opus-4-8)
# or an alias (opus / sonnet / haiku). A smaller model is cheaper on your
# subscription budget; opus gives the best study material.
LEETCOACH_MODEL=claude-opus-4-8

# Name or absolute path of the `claude` executable. Leave as "claude" if it is
# on your PATH; otherwise point at the binary, e.g.
#   LEETCOACH_CLAUDE_BIN=C:\Users\you\AppData\Local\claude\claude.exe
LEETCOACH_CLAUDE_BIN=claude

# Where the generated study library is written (relative to the project root,
# or an absolute path). This directory is gitignored.
LEETCOACH_OUTPUT_DIR=output

# Path to the persisted topic index JSON (records what Learning has covered so
# later runs skip already-learned topics). Defaults to
# <LEETCOACH_OUTPUT_DIR>/topic_index.json; set this to relocate it.
LEETCOACH_TOPIC_INDEX=output/topic_index.json

# Wall-clock cap in seconds for a single `claude` run. If the CLI hangs (network
# stall, stuck auth prompt), the run is killed after this long and reported as a
# timeout instead of wedging forever. Must be a positive number; invalid values
# fall back to the default of 600 (10 minutes).
LEETCOACH_RUN_TIMEOUT=600
