# LeetCoach configuration. Copy to ".env" and edit, or set these in your shell.
# All eight are optional; the defaults shown work on a machine where the
# `claude` CLI is on PATH and you want the strongest model.

# Claude model id passed to `claude --model`. Use a full id (claude-opus-4-8)
# or an alias (opus / sonnet / haiku). A smaller model is cheaper on your
# subscription budget; opus gives the best study material.
LEETCOACH_MODEL=claude-opus-4-8

# Model for the short classification call that tags each run with a
# problem_type + topics. Classification is trivial, so it defaults to the
# cheapest alias regardless of LEETCOACH_MODEL; it also runs in the background
# so it never delays the streamed answer.
LEETCOACH_CLASSIFIER_MODEL=haiku

# Model for the Quick Ask lookup — the inline syntax/stdlib question box. A
# Quick Ask is a trivial lookup, so it defaults to the cheapest alias to keep
# the feature near-free regardless of LEETCOACH_MODEL.
LEETCOACH_QUICK_ASK_MODEL=haiku

# Name or absolute path of the `claude` executable. Leave as "claude" if it is
# on your PATH; otherwise point at the binary, e.g.
#   LEETCOACH_CLAUDE_BIN=C:\Users\you\AppData\Local\claude\claude.exe
LEETCOACH_CLAUDE_BIN=claude

# Where the generated study library is written. Unset, it defaults to the
# "output" directory next to the app, so launching from another working
# directory never forks the library. An explicit value here is used verbatim
# (a relative path resolves against the working directory). Gitignored.
LEETCOACH_OUTPUT_DIR=output

# Path to the persisted topic index JSON (records what Learning has covered so
# later runs skip already-learned topics). Defaults to
# <LEETCOACH_OUTPUT_DIR>/topic_index.json; set this to relocate it.
LEETCOACH_TOPIC_INDEX=output/topic_index.json

# Wall-clock cap in seconds for a single `claude` run. If the CLI hangs (network
# stall, stuck auth prompt), the run is killed after this long and reported as a
# timeout instead of wedging forever. Must be a positive number; invalid values
# fall back to the default of 600 (10 minutes).
LEETCOACH_RUN_TIMEOUT=600

# Wall-clock cap in seconds for each Answer-mode sample-verification subprocess.
# A generated solution that hangs or loops is tree-killed after this long and
# the sample reports "timed out". Must be a positive number; invalid values fall
# back to the default of 10.
LEETCOACH_VERIFY_TIMEOUT=10
